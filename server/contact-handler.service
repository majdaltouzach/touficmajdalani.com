[Unit]
Description=Contact form handler for touficmajdalani.com
After=network.target
Wants=network.target

[Service]
Type=simple
User=toufic
WorkingDirectory=/home/toufic/contact-handler
ExecStart=/usr/bin/python3 /home/toufic/contact-handler/contact_handler.py
EnvironmentFile=/etc/contact-handler.env
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=contact-handler

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/home/toufic/contact-handler

[Install]
WantedBy=multi-user.target
